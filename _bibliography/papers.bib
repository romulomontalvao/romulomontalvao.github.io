@inproceedings{Silva2018,
  author = {Silva, R M and Elias, R N and Coutinho, A L G A},
  booktitle = {II Brazilian Conference of Computational Fluid Dynamics (CBCFD)},
  title = {Finite Element Mesh Multiplication with Boundary Smoothing},
  abstract = {A procedure to recover the geometry boundary of refined finite element meshes is presented. Initially, the coarse mesh is submitted to an uniform refinement by splitting the elements, but maintaining the coarse boundary. Then, the boundary nodes of the refined mesh are filtered. To avoid search overheads, the boundary nodes and the STL vertexes are subdivided into sub-regions called BINs, and the search for closest nodes is performed only to the nodes in the same sub-region. The capability of the proposed procedure is illustrated on an example.},
  pages = {4},
  url = {https://callforpapers.galoa.com.br/br/system/files/realm/cbcfd-2018/submissions/submission-84300-611241-field_submission_fulltext_file1.pdf},
  year = {2018}
}

